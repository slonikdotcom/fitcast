# ============================================================
# FitCast — приклад env-змінних
# Скопіюй цей файл у .env.local та підстав свої значення
# .env.local не комітиться в git
# ============================================================

# Postgres connection string (Neon). Для локальної розробки — direct,
# на Vercel — pooled (з "-pooler" у endpoint'і).
DATABASE_URL=postgresql://user:password@host.eu-central-1.aws.neon.tech/dbname?sslmode=require

# Секрет для підписування JWT-cookies. Згенерувати:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-byte-random-string

# OpenWeatherMap API ключ (для проксі-ендпоінта)
OPENWEATHER_API_KEY=your-owm-key-here

# Опційно: режим розробки
NODE_ENV=development
